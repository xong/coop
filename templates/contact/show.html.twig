{% extends 'base.html.twig' %}

{% block title %}{{ contact.fullName }} - Kontakte{% endblock %}

{% block body %}
<div class="mb-4">
    <div class="text-sm text-gray-500 mb-2">
        <a href="{{ path('app_organization_show', {slug: organization.slug}) }}" class="hover:text-indigo-600">{{ organization.name }}</a>
        <span class="mx-2">/</span>
        <a href="{{ path('app_org_contacts', {slug: organization.slug}) }}" class="hover:text-indigo-600">Kontakte</a>
        <span class="mx-2">/</span>
        <span>{{ contact.fullName }}</span>
    </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    {# Left: main info + custom fields + links #}
    <div class="lg:col-span-2 space-y-5">
        {# Header card #}
        <div class="card p-6">
            <div class="flex items-start justify-between">
                <div class="flex items-center">
                    <div class="w-16 h-16 rounded-full flex items-center justify-center mr-4 flex-shrink-0
                                {% if not contact.avatar %}bg-indigo-100{% endif %}">
                        {% if contact.avatar %}
                            <img src="{{ asset(contact.avatar) }}" class="w-16 h-16 rounded-full object-cover">
                        {% else %}
                            <span class="text-indigo-700 font-bold text-2xl">{{ contact.initials }}</span>
                        {% endif %}
                    </div>
                    <div>
                        <h1 class="text-2xl font-bold text-gray-900">{{ contact.fullName }}</h1>
                        {% if contact.position or contact.company %}
                            <p class="text-gray-500 mt-0.5">
                                {{ contact.position }}{% if contact.position and contact.company %} &middot; {% endif %}{{ contact.company }}
                            </p>
                        {% endif %}
                        <p class="text-xs text-gray-400 mt-1">Erstellt von {{ contact.createdBy.fullName }} am {{ contact.createdAt|date('d.m.Y') }}</p>
                    </div>
                </div>
                <div class="flex space-x-2">
                    <a href="{{ path('app_org_contact_edit', {slug: organization.slug, id: contact.id}) }}" class="btn-secondary btn-sm">
                        Bearbeiten
                    </a>
                    <form method="post" action="{{ path('app_org_contact_delete', {slug: organization.slug, id: contact.id}) }}"
                          onsubmit="return confirm('Kontakt wirklich löschen?')">
                        <input type="hidden" name="_token" value="{{ csrf_token('delete_contact_' ~ contact.id) }}">
                        <button type="submit" class="btn-danger btn-sm">Löschen</button>
                    </form>
                </div>
            </div>

            {# Standard fields #}
            <div class="grid grid-cols-2 gap-4 mt-6 border-t border-gray-100 pt-5">
                {% if contact.email %}
                    <div>
                        <p class="text-xs text-gray-400 uppercase tracking-wide mb-0.5">E-Mail</p>
                        <a href="mailto:{{ contact.email }}" class="text-indigo-600 hover:underline text-sm">{{ contact.email }}</a>
                    </div>
                {% endif %}
                {% if contact.phone %}
                    <div>
                        <p class="text-xs text-gray-400 uppercase tracking-wide mb-0.5">Telefon</p>
                        <a href="tel:{{ contact.phone }}" class="text-sm text-gray-700 hover:text-indigo-600">{{ contact.phone }}</a>
                    </div>
                {% endif %}
                {% if contact.website %}
                    <div>
                        <p class="text-xs text-gray-400 uppercase tracking-wide mb-0.5">Website</p>
                        <a href="{{ contact.website }}" target="_blank" class="text-indigo-600 hover:underline text-sm truncate block">{{ contact.website }}</a>
                    </div>
                {% endif %}
                {% if contact.address %}
                    <div class="col-span-2">
                        <p class="text-xs text-gray-400 uppercase tracking-wide mb-0.5">Adresse</p>
                        <p class="text-sm text-gray-700 whitespace-pre-line">{{ contact.address }}</p>
                    </div>
                {% endif %}
            </div>

            {# Custom fields #}
            {% if contact.customFields|length > 0 %}
                <div class="border-t border-gray-100 pt-5 mt-4">
                    <h3 class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-3">Weitere Felder</h3>
                    <div class="grid grid-cols-2 gap-3">
                        {% for field in contact.customFields %}
                            <div>
                                <p class="text-xs text-gray-400 uppercase tracking-wide mb-0.5">{{ field.label }}</p>
                                <p class="text-sm text-gray-700">{{ field.value }}</p>
                            </div>
                        {% endfor %}
                    </div>
                </div>
            {% endif %}

            {# Notes #}
            {% if contact.notes %}
                <div class="border-t border-gray-100 pt-5 mt-4">
                    <h3 class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-2">Notizen</h3>
                    <p class="text-sm text-gray-700 whitespace-pre-line">{{ contact.notes }}</p>
                </div>
            {% endif %}
        </div>

        {# Linked projects & topics #}
        {% if contact.linkedProjects|length > 0 or contact.linkedTopics|length > 0 %}
            <div class="card p-5">
                <h3 class="font-semibold text-gray-900 mb-3">Verknüpfungen</h3>
                {% if contact.linkedProjects|length > 0 %}
                    <div class="mb-3">
                        <p class="text-xs text-gray-400 uppercase tracking-wide mb-2">Projekte</p>
                        <div class="flex flex-wrap gap-2">
                            {% for project in contact.linkedProjects %}
                                <a href="{{ path('app_project_show', {slug: organization.slug, projectSlug: project.slug}) }}"
                                   class="inline-flex items-center px-3 py-1 rounded-full bg-indigo-50 text-indigo-700 text-sm hover:bg-indigo-100">
                                    &#128193; {{ project.name }}
                                </a>
                            {% endfor %}
                        </div>
                    </div>
                {% endif %}
                {% if contact.linkedTopics|length > 0 %}
                    <div>
                        <p class="text-xs text-gray-400 uppercase tracking-wide mb-2">Themen</p>
                        <div class="flex flex-wrap gap-2">
                            {% for topic in contact.linkedTopics %}
                                <a href="{{ path('app_topic_show', {id: topic.id}) }}"
                                   class="inline-flex items-center px-3 py-1 rounded-full bg-purple-50 text-purple-700 text-sm hover:bg-purple-100">
                                    &#128172; {{ topic.title|slice(0, 50) }}
                                </a>
                            {% endfor %}
                        </div>
                    </div>
                {% endif %}
            </div>
        {% endif %}

        {# Comments #}
        <div class="card p-6">
            <h3 class="font-semibold text-gray-900 mb-4">Notizen & Kommentare ({{ contact.comments|length }})</h3>

            {% if contact.comments is empty %}
                <p class="text-gray-400 text-sm mb-4">Noch keine Kommentare.</p>
            {% else %}
                <div class="space-y-4 mb-6">
                    {% for comment in contact.comments %}
                        <div class="flex items-start space-x-3">
                            <div class="w-8 h-8 rounded-full bg-gray-100 flex items-center justify-center flex-shrink-0">
                                <span class="text-gray-600 text-xs font-bold">
                                    {{ comment.author.firstName|first }}{{ comment.author.lastName|first }}
                                </span>
                            </div>
                            <div class="flex-1">
                                <div class="bg-gray-50 rounded-lg px-4 py-3">
                                    <div class="flex items-center justify-between mb-1">
                                        <p class="text-sm font-medium text-gray-900">{{ comment.author.fullName }}</p>
                                        <p class="text-xs text-gray-400">{{ comment.createdAt|date('d.m.Y H:i') }}</p>
                                    </div>
                                    <p class="text-sm text-gray-700 whitespace-pre-wrap">{{ comment.content }}</p>
                                </div>
                                {% if comment.author == app.user %}
                                    <form method="post"
                                          action="{{ path('app_org_contact_comment_delete', {slug: organization.slug, id: contact.id, commentId: comment.id}) }}"
                                          class="mt-1 ml-1">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete_contact_comment_' ~ comment.id) }}">
                                        <button type="submit" class="text-xs text-red-400 hover:text-red-600">Löschen</button>
                                    </form>
                                {% endif %}
                            </div>
                        </div>
                    {% endfor %}
                </div>
            {% endif %}

            <form method="post" action="{{ path('app_org_contact_comment', {slug: organization.slug, id: contact.id}) }}">
                <input type="hidden" name="_token" value="{{ csrf_token('contact_comment_' ~ contact.id) }}">
                <textarea name="content" rows="3" placeholder="Kommentar hinzufügen..."
                    class="form-input w-full"></textarea>
                <div class="mt-2">
                    <button type="submit" class="btn-primary btn-sm">Kommentar speichern</button>
                </div>
            </form>
        </div>
    </div>

    {# Right sidebar #}
    <div class="space-y-4">
        <div class="card p-5">
            <h3 class="font-semibold text-gray-900 mb-3">Schnellaktionen</h3>
            <div class="space-y-2">
                {% if contact.email %}
                    {% if mailboxes|length > 0 %}
                        <a href="{{ path('app_org_compose', {slug: organization.slug, contact_id: contact.id}) }}"
                           class="flex items-center text-sm text-indigo-600 hover:text-indigo-800">
                            <span class="mr-2">&#9993;</span> E-Mail schreiben
                        </a>
                    {% else %}
                        <a href="mailto:{{ contact.email }}" class="flex items-center text-sm text-indigo-600 hover:text-indigo-800">
                            <span class="mr-2">&#9993;</span> E-Mail schreiben
                        </a>
                    {% endif %}
                {% endif %}
                {% if contact.phone %}
                    <a href="tel:{{ contact.phone }}" class="flex items-center text-sm text-indigo-600 hover:text-indigo-800">
                        <span class="mr-2">&#128222;</span> Anrufen
                    </a>
                {% endif %}
                {% if contact.website %}
                    <a href="{{ contact.website }}" target="_blank" class="flex items-center text-sm text-indigo-600 hover:text-indigo-800">
                        <span class="mr-2">&#127758;</span> Website besuchen
                    </a>
                {% endif %}
                <a href="{{ path('app_org_contact_edit', {slug: organization.slug, id: contact.id}) }}"
                   class="flex items-center text-sm text-gray-600 hover:text-gray-800">
                    <span class="mr-2">&#9998;</span> Bearbeiten
                </a>
            </div>
        </div>

        <div class="card p-5">
            <h3 class="font-semibold text-gray-900 mb-2">Zuletzt aktualisiert</h3>
            <p class="text-sm text-gray-500">{{ contact.updatedAt|date('d.m.Y H:i') }}</p>
            <p class="text-xs text-gray-400 mt-1">Erstellt: {{ contact.createdAt|date('d.m.Y') }}</p>
        </div>
    </div>
</div>
{% endblock %}
