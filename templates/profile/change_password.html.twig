{% extends 'base.html.twig' %}

{% block title %}Passwort andern{% endblock %}

{% block body %}
<div class="max-w-md mx-auto">
    <div class="mb-6">
        <a href="{{ path('app_profile') }}" class="text-indigo-600 hover:text-indigo-800 text-sm">&larr; Zuruck zum Profil</a>
        <h1 class="text-2xl font-bold text-gray-900 mt-2">Passwort andern</h1>
    </div>

    <div class="card p-6">
        {{ form_start(form, {attr: {class: 'space-y-5'}}) }}
            <div>
                {{ form_label(form.currentPassword, null, {label_attr: {class: 'form-label'}}) }}
                {{ form_widget(form.currentPassword, {attr: {class: 'form-input'}}) }}
                {{ form_errors(form.currentPassword) }}
            </div>
            <div>
                {{ form_label(form.newPassword.first, null, {label_attr: {class: 'form-label'}}) }}
                {{ form_widget(form.newPassword.first, {attr: {class: 'form-input'}}) }}
                {{ form_errors(form.newPassword.first) }}
            </div>
            <div>
                {{ form_label(form.newPassword.second, null, {label_attr: {class: 'form-label'}}) }}
                {{ form_widget(form.newPassword.second, {attr: {class: 'form-input'}}) }}
                {{ form_errors(form.newPassword.second) }}
            </div>
            <div class="flex space-x-3 pt-2">
                <button type="submit" class="btn-primary">Passwort andern</button>
                <a href="{{ path('app_profile') }}" class="btn-secondary">Abbrechen</a>
            </div>
        {{ form_end(form) }}
    </div>
</div>
{% endblock %}
