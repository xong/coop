{% extends 'base.html.twig' %}

{% block title %}{{ project.name }} bearbeiten{% endblock %}

{% block body %}
<div class="max-w-2xl mx-auto">
    <div class="mb-6">
        <a href="{{ path('app_project_show', {slug: organization.slug, projectSlug: project.slug}) }}" class="text-indigo-600 hover:text-indigo-800 text-sm">&larr; {{ project.name }}</a>
        <h1 class="text-2xl font-bold text-gray-900 mt-2">Projekt bearbeiten</h1>
    </div>
    <div class="card p-6">
        {{ form_start(form, {attr: {class: 'space-y-5'}}) }}
            <div>
                {{ form_label(form.name, null, {label_attr: {class: 'form-label'}}) }}
                {{ form_widget(form.name, {attr: {class: 'form-input'}}) }}
                {{ form_errors(form.name) }}
            </div>
            <div>
                {{ form_label(form.description, null, {label_attr: {class: 'form-label'}}) }}
                {{ form_widget(form.description, {attr: {class: 'form-input'}}) }}
                {{ form_errors(form.description) }}
            </div>
            <div class="flex items-start">
                {{ form_widget(form.isPublic, {attr: {class: 'mt-1 rounded border-gray-300'}}) }}
                <div class="ml-3">
                    {{ form_label(form.isPublic, null, {label_attr: {class: 'text-sm font-medium text-gray-700 cursor-pointer'}}) }}
                    {{ form_errors(form.isPublic) }}
                </div>
            </div>
            <div class="flex space-x-3 pt-2">
                <button type="submit" class="btn-primary">Speichern</button>
                <a href="{{ path('app_project_show', {slug: organization.slug, projectSlug: project.slug}) }}" class="btn-secondary">Abbrechen</a>
            </div>
        {{ form_end(form) }}
    </div>
</div>
{% endblock %}
