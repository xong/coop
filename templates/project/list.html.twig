{% extends 'base.html.twig' %}

{% block title %}Projekte - {{ organization.name }}{% endblock %}

{% block body %}
<div class="mb-8 flex items-center justify-between">
    <div>
        <a href="{{ path('app_organization_show', {slug: organization.slug}) }}" class="text-indigo-600 hover:text-indigo-800 text-sm">&larr; {{ organization.name }}</a>
        <h1 class="text-2xl font-bold text-gray-900 mt-1">Projekte</h1>
    </div>
    <a href="{{ path('app_project_new', {slug: organization.slug}) }}" class="btn-primary">
        <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
        </svg>
        Neues Projekt
    </a>
</div>

{% if projects is empty %}
    <div class="card p-12 text-center">
        <div class="text-4xl mb-3">&#128194;</div>
        <h3 class="text-lg font-medium text-gray-900 mb-2">Keine Projekte</h3>
        <p class="text-gray-500 mb-6">Erstelle das erste Projekt dieser Organisation.</p>
        <a href="{{ path('app_project_new', {slug: organization.slug}) }}" class="btn-primary">Projekt erstellen</a>
    </div>
{% else %}
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {% for project in projects %}
            <a href="{{ path('app_project_show', {slug: organization.slug, projectSlug: project.slug}) }}"
                class="card p-6 hover:shadow-md transition-shadow group">
                <div class="flex items-start justify-between mb-3">
                    <h3 class="font-semibold text-gray-900 group-hover:text-indigo-700 transition-colors">{{ project.name }}</h3>
                    {% if project.isPublic %}
                        <span class="badge-green ml-2">Offentlich</span>
                    {% else %}
                        <span class="badge-gray ml-2">Privat</span>
                    {% endif %}
                </div>
                {% if project.description %}
                    <p class="text-gray-500 text-sm line-clamp-2 mb-3">{{ project.description }}</p>
                {% endif %}
                <div class="text-xs text-gray-400">
                    {{ project.members|length }} Mitglieder &middot; {{ project.createdAt|date('d.m.Y') }}
                </div>
            </a>
        {% endfor %}
    </div>
{% endif %}
{% endblock %}
