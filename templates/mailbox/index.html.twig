{% extends 'base.html.twig' %}

{% block title %}E-Mail-Postfächer{% endblock %}

{% block body %}
<div class="mb-6">
    <div class="text-sm text-gray-500 mb-2">
        <a href="{{ path('app_organization_show', {slug: organization.slug}) }}" class="hover:text-indigo-600">{{ organization.name }}</a>
        {% if project %}
            <span class="mx-2">/</span>
            <a href="{{ path('app_project_show', {slug: organization.slug, projectSlug: project.slug}) }}" class="hover:text-indigo-600">{{ project.name }}</a>
        {% endif %}
        <span class="mx-2">/</span>
        <span>E-Mail-Postfächer</span>
    </div>
    <div class="flex items-center justify-between">
        <h1 class="text-2xl font-bold text-gray-900">E-Mail-Postfächer</h1>
        {% if project %}
            {% if project.isAdmin(app.user) %}
                <a href="{{ path('app_project_mailbox_new', {slug: organization.slug, projectSlug: project.slug}) }}" class="btn-primary btn-sm">
                    + Postfach einrichten
                </a>
            {% endif %}
        {% else %}
            {% if organization.isAdmin(app.user) %}
                <a href="{{ path('app_org_mailbox_new', {slug: organization.slug}) }}" class="btn-primary btn-sm">
                    + Postfach einrichten
                </a>
            {% endif %}
        {% endif %}
    </div>
</div>

{% if mailboxes is empty %}
    <div class="card p-10 text-center">
        <div class="text-4xl mb-3">&#128231;</div>
        <h3 class="font-medium text-gray-900 mb-2">Noch keine Postfächer konfiguriert</h3>
        <p class="text-gray-500 mb-4">Richten Sie ein gemeinsames E-Mail-Postfach ein, um E-Mails als Team zu verwalten.</p>
        {% if project %}
            {% if project.isAdmin(app.user) %}
                <a href="{{ path('app_project_mailbox_new', {slug: organization.slug, projectSlug: project.slug}) }}" class="btn-primary">Postfach einrichten</a>
            {% endif %}
        {% else %}
            {% if organization.isAdmin(app.user) %}
                <a href="{{ path('app_org_mailbox_new', {slug: organization.slug}) }}" class="btn-primary">Postfach einrichten</a>
            {% endif %}
        {% endif %}
    </div>
{% else %}
    <div class="space-y-3">
        {% for config in mailboxes %}
            <div class="card p-5">
                <div class="flex items-center justify-between">
                    <div class="flex items-center space-x-4">
                        <div class="w-10 h-10 rounded-full bg-indigo-100 flex items-center justify-center">
                            <span class="text-indigo-700 text-lg">&#128231;</span>
                        </div>
                        <div>
                            <div class="flex items-center space-x-2">
                                <h3 class="font-semibold text-gray-900">{{ config.name }}</h3>
                                {% if config.isActive %}
                                    <span class="badge-green">Aktiv</span>
                                {% else %}
                                    <span class="badge-gray">Inaktiv</span>
                                {% endif %}
                                {% if config.unreadCount > 0 %}
                                    <span class="badge-blue">{{ config.unreadCount }} ungelesen</span>
                                {% endif %}
                            </div>
                            <p class="text-sm text-gray-500">{{ config.fromEmail }} &middot; {{ config.imapHost }}</p>
                            {% if config.lastSyncAt %}
                                <p class="text-xs text-gray-400 mt-1">
                                    Letzter Abruf: {{ config.lastSyncAt|date('d.m.Y H:i') }}
                                    {% if config.lastSyncError %}
                                        &middot; <span class="text-red-500">Fehler: {{ config.lastSyncError|slice(0, 80) }}</span>
                                    {% endif %}
                                </p>
                            {% endif %}
                        </div>
                    </div>
                    <div class="flex items-center space-x-2">
                        {% if project %}
                            <a href="{{ path('app_project_mailbox_inbox', {slug: organization.slug, projectSlug: project.slug, id: config.id}) }}" class="btn-secondary btn-sm">
                                Posteingang
                            </a>
                            {% if project.isAdmin(app.user) %}
                                <form method="post" action="{{ path('app_project_mailbox_sync', {slug: organization.slug, projectSlug: project.slug, id: config.id}) }}">
                                    <input type="hidden" name="_token" value="{{ csrf_token('sync_mailbox_' ~ config.id) }}">
                                    <button type="submit" class="btn-secondary btn-sm">Abrufen</button>
                                </form>
                                <a href="{{ path('app_project_mailbox_edit', {slug: organization.slug, projectSlug: project.slug, id: config.id}) }}" class="btn-secondary btn-sm">Bearbeiten</a>
                                <form method="post" action="{{ path('app_project_mailbox_delete', {slug: organization.slug, projectSlug: project.slug, id: config.id}) }}"
                                      onsubmit="return confirm('Postfach wirklich löschen?')">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete_mailbox_' ~ config.id) }}">
                                    <button type="submit" class="btn-danger btn-sm">Löschen</button>
                                </form>
                            {% endif %}
                        {% else %}
                            <a href="{{ path('app_org_mailbox_inbox', {slug: organization.slug, id: config.id}) }}" class="btn-secondary btn-sm">
                                Posteingang
                            </a>
                            {% if organization.isAdmin(app.user) %}
                                <form method="post" action="{{ path('app_org_mailbox_sync', {slug: organization.slug, id: config.id}) }}">
                                    <input type="hidden" name="_token" value="{{ csrf_token('sync_mailbox_' ~ config.id) }}">
                                    <button type="submit" class="btn-secondary btn-sm">Abrufen</button>
                                </form>
                                <a href="{{ path('app_org_mailbox_edit', {slug: organization.slug, id: config.id}) }}" class="btn-secondary btn-sm">Bearbeiten</a>
                                <form method="post" action="{{ path('app_org_mailbox_delete', {slug: organization.slug, id: config.id}) }}"
                                      onsubmit="return confirm('Postfach wirklich löschen?')">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete_mailbox_' ~ config.id) }}">
                                    <button type="submit" class="btn-danger btn-sm">Löschen</button>
                                </form>
                            {% endif %}
                        {% endif %}
                    </div>
                </div>
            </div>
        {% endfor %}
    </div>
{% endif %}
{% endblock %}
