{% extends 'base.html.twig' %}

{% block title %}Meine Organisationen{% endblock %}

{% block body %}
<div class="mb-8 flex items-center justify-between">
    <h1 class="text-2xl font-bold text-gray-900">Meine Organisationen</h1>
    <a href="{{ path('app_organization_new') }}" class="btn-primary">
        <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
        </svg>
        Neue Organisation
    </a>
</div>

{% if organizations is empty %}
    <div class="card p-12 text-center">
        <div class="text-4xl mb-3">&#127970;</div>
        <h3 class="text-lg font-medium text-gray-900 mb-2">Keine Organisationen</h3>
        <p class="text-gray-500 mb-6">Erstelle eine Organisation oder warte auf eine Einladung.</p>
        <a href="{{ path('app_organization_new') }}" class="btn-primary">Organisation erstellen</a>
    </div>
{% else %}
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {% for org in organizations %}
            <div class="card overflow-hidden hover:shadow-md transition-shadow">
                <div class="p-6">
                    <div class="flex items-center mb-3">
                        {% if org.logo %}
                            <img src="{{ asset(org.logo) }}" class="w-10 h-10 rounded-lg object-cover mr-3">
                        {% else %}
                            <div class="w-10 h-10 rounded-lg bg-indigo-100 flex items-center justify-center mr-3">
                                <span class="text-indigo-700 font-bold">{{ org.name|first|upper }}</span>
                            </div>
                        {% endif %}
                        <div class="flex-1 min-w-0">
                            <h3 class="font-semibold text-gray-900 truncate">{{ org.name }}</h3>
                            <p class="text-xs text-gray-400">{{ org.members|length }} Mitglieder</p>
                        </div>
                        {% if org.isAdmin(app.user) %}
                            <span class="badge-blue ml-2">Admin</span>
                        {% endif %}
                    </div>
                    {% if org.description %}
                        <p class="text-gray-500 text-sm line-clamp-2 mb-3">{{ org.description }}</p>
                    {% endif %}
                </div>
                <div class="px-6 pb-4 flex space-x-2">
                    <a href="{{ path('app_organization_show', {slug: org.slug}) }}" class="btn-primary btn-sm flex-1 justify-center">
                        Offnen
                    </a>
                    {% if org.isAdmin(app.user) %}
                        <a href="{{ path('app_organization_edit', {slug: org.slug}) }}" class="btn-secondary btn-sm">
                            Bearbeiten
                        </a>
                    {% endif %}
                </div>
            </div>
        {% endfor %}
    </div>
{% endif %}
{% endblock %}
