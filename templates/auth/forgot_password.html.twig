{% extends 'auth_base.html.twig' %}

{% block title %}Passwort vergessen{% endblock %}

{% block body %}
<div class="sm:mx-auto sm:w-full sm:max-w-md">
    <div class="bg-white py-8 px-4 shadow-md sm:rounded-xl sm:px-10 border border-gray-200">
        <h2 class="text-2xl font-bold text-gray-900 mb-2 text-center">Passwort vergessen</h2>

        {% if submitted %}
            <div class="text-center py-4">
                <div class="text-4xl mb-3">&#128231;</div>
                <p class="text-gray-700 mb-2">Falls ein Konto mit dieser E-Mail-Adresse existiert, wurde eine E-Mail gesendet.</p>
                <p class="text-gray-500 text-sm">Bitte pruf dein Postfach und den Spam-Ordner.</p>
                <a href="{{ path('app_login') }}" class="btn-primary mt-6 inline-block">Zuruck zum Login</a>
            </div>
        {% else %}
            <p class="text-gray-500 text-sm mb-6 text-center">Gib deine E-Mail-Adresse ein. Wir senden dir einen Link zum Zurucksetzen deines Passworts.</p>
            <form method="post" class="space-y-4">
                <div>
                    <label for="email" class="form-label">E-Mail-Adresse</label>
                    <input type="email" id="email" name="email" required autofocus class="form-input"
                        placeholder="max@beispiel.de">
                </div>
                <button type="submit" class="btn-primary w-full justify-center py-2.5">
                    Passwort zurucksetzen
                </button>
            </form>
            <p class="mt-4 text-center text-sm">
                <a href="{{ path('app_login') }}" class="text-indigo-600 hover:text-indigo-800">Zuruck zum Login</a>
            </p>
        {% endif %}
    </div>
</div>
{% endblock %}
