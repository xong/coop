{% extends 'auth_base.html.twig' %}

{% block title %}Registrieren{% endblock %}

{% block body %}
<div class="sm:mx-auto sm:w-full sm:max-w-md">
    <div class="bg-white py-8 px-4 shadow-md sm:rounded-xl sm:px-10 border border-gray-200">
        <h2 class="text-2xl font-bold text-gray-900 mb-6 text-center">Konto erstellen</h2>

        {{ form_start(form, {attr: {class: 'space-y-4'}}) }}
            <div class="grid grid-cols-2 gap-4">
                <div>
                    {{ form_label(form.firstName, null, {label_attr: {class: 'form-label'}}) }}
                    {{ form_widget(form.firstName, {attr: {class: 'form-input'}}) }}
                    {{ form_errors(form.firstName) }}
                </div>
                <div>
                    {{ form_label(form.lastName, null, {label_attr: {class: 'form-label'}}) }}
                    {{ form_widget(form.lastName, {attr: {class: 'form-input'}}) }}
                    {{ form_errors(form.lastName) }}
                </div>
            </div>

            <div>
                {{ form_label(form.email, null, {label_attr: {class: 'form-label'}}) }}
                {{ form_widget(form.email, {attr: {class: 'form-input'}}) }}
                {{ form_errors(form.email) }}
            </div>

            <div>
                {{ form_label(form.plainPassword.first, null, {label_attr: {class: 'form-label'}}) }}
                {{ form_widget(form.plainPassword.first, {attr: {class: 'form-input'}}) }}
                {{ form_errors(form.plainPassword.first) }}
            </div>

            <div>
                {{ form_label(form.plainPassword.second, null, {label_attr: {class: 'form-label'}}) }}
                {{ form_widget(form.plainPassword.second, {attr: {class: 'form-input'}}) }}
                {{ form_errors(form.plainPassword.second) }}
            </div>

            <div class="flex items-start">
                {{ form_widget(form.agreeTerms, {attr: {class: 'mt-0.5 rounded border-gray-300'}}) }}
                <div class="ml-2">
                    {{ form_label(form.agreeTerms, null, {label_attr: {class: 'text-sm text-gray-600 cursor-pointer'}}) }}
                    {{ form_errors(form.agreeTerms) }}
                </div>
            </div>

            <button type="submit" class="btn-primary w-full justify-center py-2.5">
                Konto erstellen
            </button>
        {{ form_end(form) }}

        <p class="mt-6 text-center text-sm text-gray-600">
            Bereits ein Konto?
            <a href="{{ path('app_login') }}" class="text-indigo-600 font-medium hover:text-indigo-800">
                Anmelden
            </a>
        </p>
    </div>
</div>
{% endblock %}
