{% extends 'auth_base.html.twig' %}

{% block title %}Anmelden{% endblock %}

{% block body %}
<div class="sm:mx-auto sm:w-full sm:max-w-md">
    <div class="bg-white py-8 px-4 shadow-md sm:rounded-xl sm:px-10 border border-gray-200">
        <h2 class="text-2xl font-bold text-gray-900 mb-6 text-center">Anmelden</h2>

        {% if error %}
            <div class="mb-4 p-3 bg-red-50 border border-red-200 rounded-lg text-red-700 text-sm">
                {{ error.messageKey|trans(error.messageData, 'security') }}
            </div>
        {% endif %}

        <form method="post">
            <div class="mb-4">
                <label for="inputEmail" class="form-label">E-Mail-Adresse</label>
                <input type="email" id="inputEmail" name="_username" value="{{ last_username }}"
                    autocomplete="email" required autofocus
                    class="form-input">
            </div>

            <div class="mb-4">
                <label for="inputPassword" class="form-label">Passwort</label>
                <input type="password" id="inputPassword" name="_password"
                    autocomplete="current-password" required
                    class="form-input">
            </div>

            <div class="flex items-center justify-between mb-6">
                <label class="flex items-center text-sm text-gray-600">
                    <input type="checkbox" name="_remember_me" class="mr-2 rounded border-gray-300">
                    Angemeldet bleiben
                </label>
                <a href="{{ path('app_forgot_password_request') }}" class="text-sm text-indigo-600 hover:text-indigo-800">
                    Passwort vergessen?
                </a>
            </div>

            <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">
            <button type="submit" class="btn-primary w-full justify-center py-2.5">
                Anmelden
            </button>
        </form>

        <p class="mt-6 text-center text-sm text-gray-600">
            Noch kein Konto?
            <a href="{{ path('app_register') }}" class="text-indigo-600 font-medium hover:text-indigo-800">
                Jetzt registrieren
            </a>
        </p>
    </div>
</div>
{% endblock %}
