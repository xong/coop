<div class="min-h-full flex flex-col justify-center py-12 sm:px-6 lg:px-8 bg-gray-50">
    <div class="sm:mx-auto sm:w-full sm:max-w-md">
        <div class="text-center mb-6">
            <span class="text-5xl">&#129309;</span>
            <h1 class="mt-2 text-3xl font-extrabold text-gray-900">coop</h1>
            <p class="text-gray-500 text-sm">Kollaborationssoftware</p>
        </div>
    </div>

    {% for type, messages in app.flashes %}
        {% for message in messages %}
            {% set colors = {
                'success': 'bg-green-50 border-green-400 text-green-800',
                'error': 'bg-red-50 border-red-400 text-red-800',
                'warning': 'bg-yellow-50 border-yellow-400 text-yellow-800',
                'info': 'bg-blue-50 border-blue-400 text-blue-800'
            } %}
            <div class="sm:mx-auto sm:w-full sm:max-w-md mb-4" x-data="{ show: true }" x-show="show">
                <div class="flex items-center justify-between p-4 border-l-4 rounded-lg {{ colors[type] ?? 'bg-gray-50 border-gray-400 text-gray-800' }}">
                    <span>{{ message }}</span>
                    <button @click="show = false" class="ml-4 opacity-60 hover:opacity-100">&times;</button>
                </div>
            </div>
        {% endfor %}
    {% endfor %}

    {% block body %}{% endblock %}
</div>
