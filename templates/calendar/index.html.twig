{% extends 'base.html.twig' %}

{% block title %}Kalender - {{ organization.name }}{% endblock %}

{% block body %}
<div class="mb-6 flex items-center justify-between">
    <div>
        <a href="{{ path('app_organization_show', {slug: organization.slug}) }}" class="text-indigo-600 hover:text-indigo-800 text-sm">&larr; {{ organization.name }}</a>
        <h1 class="text-2xl font-bold text-gray-900 mt-1">Kalender</h1>
    </div>
    <div class="flex space-x-2">
        <a href="{{ path('app_org_tasks', {slug: organization.slug}) }}" class="btn-secondary btn-sm">&#9989; Aufgaben</a>
        <a href="{{ path('app_org_event_new', {slug: organization.slug}) }}" class="btn-primary btn-sm">+ Neuer Termin</a>
    </div>
</div>

<div class="flex gap-6">
    {# Calendar grid #}
    <div class="flex-1">
        {# Month navigation #}
        <div class="card p-4 mb-4 flex items-center justify-between">
            <a href="{{ path('app_org_calendar', {slug: organization.slug, year: prevYear, month: prevMonth}) }}"
                class="btn-secondary btn-sm">&larr;</a>
            <h2 class="text-lg font-semibold text-gray-900">
                {{ monthName|replace({'January': 'Januar', 'February': 'Februar', 'March': 'März', 'April': 'April', 'May': 'Mai', 'June': 'Juni', 'July': 'Juli', 'August': 'August', 'September': 'September', 'October': 'Oktober', 'November': 'November', 'December': 'Dezember'}) }}
            </h2>
            <a href="{{ path('app_org_calendar', {slug: organization.slug, year: nextYear, month: nextMonth}) }}"
                class="btn-secondary btn-sm">&rarr;</a>
        </div>

        <div class="card overflow-hidden">
            {# Weekday headers #}
            <div class="grid grid-cols-7 bg-gray-50 border-b border-gray-200">
                {% for day in ['Mo', 'Di', 'Mi', 'Do', 'Fr', 'Sa', 'So'] %}
                    <div class="py-2 text-center text-xs font-semibold text-gray-500 uppercase tracking-wide">{{ day }}</div>
                {% endfor %}
            </div>

            {# Calendar grid #}
            <div class="grid grid-cols-7 divide-x divide-gray-100">
                {% set today = "now"|date("Y-m-d") %}
                {% for day in grid %}
                    {% if day is null %}
                        <div class="min-h-24 bg-gray-50/50 p-2"></div>
                    {% else %}
                        {% set dateKey = day|date('Y-m-d') %}
                        {% set isToday = dateKey == today %}
                        {% set dayEvents = eventsByDate[dateKey] ?? [] %}
                        {% set dayTasks = tasksByDate[dateKey] ?? [] %}
                        <div class="min-h-24 p-2 border-b border-gray-100 {{ isToday ? 'bg-indigo-50' : '' }}">
                            <div class="mb-1">
                                <span class="text-sm font-medium {{ isToday ? 'bg-indigo-600 text-white w-6 h-6 rounded-full flex items-center justify-center' : 'text-gray-700' }}">
                                    {{ day|date('j') }}
                                </span>
                            </div>
                            {% for event in dayEvents %}
                                <a href="{{ path('app_org_event_edit', {slug: organization.slug, id: event.id}) }}"
                                    class="block text-xs bg-indigo-100 text-indigo-800 rounded px-1 py-0.5 mb-0.5 truncate hover:bg-indigo-200" title="{{ event.title }}">
                                    {% if not event.allDay %}{{ event.startAt|date('H:i') }} {% endif %}{{ event.title }}
                                </a>
                            {% endfor %}
                            {% for task in dayTasks %}
                                <a href="{{ path('app_task_show', {id: task.id}) }}"
                                    class="block text-xs bg-amber-100 text-amber-800 rounded px-1 py-0.5 mb-0.5 truncate hover:bg-amber-200" title="{{ task.title }}">
                                    &#9989; {{ task.title }}
                                </a>
                            {% endfor %}
                        </div>
                    {% endif %}
                {% endfor %}
            </div>
        </div>
    </div>

    {# Sidebar: upcoming events #}
    <div class="w-64 flex-shrink-0">
        <div class="card p-4">
            <h3 class="font-semibold text-gray-900 mb-3 text-sm">Bevorstehende Termine</h3>
            {% set futureEvents = upcomingEvents|filter(e => e.startAt >= date()) %}
            {% if futureEvents is empty %}
                <p class="text-sm text-gray-400">Keine bevorstehenden Termine.</p>
            {% else %}
                <div class="space-y-3">
                    {% for event in futureEvents|slice(0, 8) %}
                        <div class="border-l-2 border-indigo-300 pl-3">
                            <p class="text-sm font-medium text-gray-900 truncate">{{ event.title }}</p>
                            <p class="text-xs text-gray-500">
                                {{ event.startAt|date('d.m.Y') }}
                                {% if not event.allDay %} {{ event.startAt|date('H:i') }}{% endif %}
                            </p>
                            {% if event.location %}
                                <p class="text-xs text-gray-400 truncate">&#128205; {{ event.location }}</p>
                            {% endif %}
                            <div class="flex space-x-2 mt-1">
                                <a href="{{ path('app_org_event_edit', {slug: organization.slug, id: event.id}) }}" class="text-xs text-indigo-500 hover:text-indigo-700">Bearbeiten</a>
                                <form method="post" action="{{ path('app_org_event_delete', {slug: organization.slug, id: event.id}) }}"
                                    x-data @submit.prevent="if(confirm('Termin löschen?')) $el.submit()">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete_event_' ~ event.id) }}">
                                    <button class="text-xs text-red-400 hover:text-red-600">Löschen</button>
                                </form>
                            </div>
                        </div>
                    {% endfor %}
                </div>
            {% endif %}
        </div>

        <div class="card p-4 mt-4">
            <div class="flex items-center space-x-2 mb-2 text-xs text-gray-500">
                <span class="w-3 h-3 bg-indigo-200 rounded block"></span>
                <span>Termin</span>
            </div>
            <div class="flex items-center space-x-2 text-xs text-gray-500">
                <span class="w-3 h-3 bg-amber-200 rounded block"></span>
                <span>Aufgabe (fällig)</span>
            </div>
        </div>
    </div>
</div>
{% endblock %}
