{% extends 'base.html.twig' %}

{% block title %}{{ event.id ? 'Termin bearbeiten' : 'Neuer Termin' }}{% endblock %}

{% block body %}
<div class="max-w-2xl mx-auto">
    <div class="mb-6">
        <a href="{{ backUrl }}" class="text-indigo-600 hover:text-indigo-800 text-sm">&larr; Zurück zum Kalender</a>
        <h1 class="text-2xl font-bold text-gray-900 mt-2">
            {{ event.id ? 'Termin bearbeiten' : 'Neuen Termin erstellen' }}
        </h1>
    </div>

    <div class="card p-6">
        {{ form_start(form, {attr: {class: 'space-y-5'}}) }}
            <div>
                {{ form_label(form.title, null, {label_attr: {class: 'form-label'}}) }}
                {{ form_widget(form.title, {attr: {class: 'form-input'}}) }}
                {{ form_errors(form.title) }}
            </div>
            <div>
                {{ form_label(form.description, null, {label_attr: {class: 'form-label'}}) }}
                {{ form_widget(form.description, {attr: {class: 'form-input'}}) }}
                {{ form_errors(form.description) }}
            </div>
            <div>
                {{ form_label(form.location, null, {label_attr: {class: 'form-label'}}) }}
                {{ form_widget(form.location, {attr: {class: 'form-input'}}) }}
                {{ form_errors(form.location) }}
            </div>
            <div class="flex items-center space-x-3">
                {{ form_widget(form.allDay, {attr: {class: 'rounded border-gray-300'}}) }}
                {{ form_label(form.allDay, null, {label_attr: {class: 'text-sm font-medium text-gray-700 cursor-pointer'}}) }}
            </div>
            <div class="grid grid-cols-2 gap-4">
                <div>
                    {{ form_label(form.startAt, null, {label_attr: {class: 'form-label'}}) }}
                    {{ form_widget(form.startAt, {attr: {class: 'form-input'}}) }}
                    {{ form_errors(form.startAt) }}
                </div>
                <div>
                    {{ form_label(form.endAt, null, {label_attr: {class: 'form-label'}}) }}
                    {{ form_widget(form.endAt, {attr: {class: 'form-input'}}) }}
                    {{ form_errors(form.endAt) }}
                </div>
            </div>
            <div>
                {{ form_label(form.attendees, null, {label_attr: {class: 'form-label'}}) }}
                <p class="text-xs text-gray-400 mb-1">Mehrfachauswahl mit Strg/Cmd</p>
                {{ form_widget(form.attendees, {attr: {class: 'form-input'}}) }}
                {{ form_errors(form.attendees) }}
            </div>
            <div class="flex space-x-3 pt-2">
                <button type="submit" class="btn-primary">{{ event.id ? 'Speichern' : 'Termin erstellen' }}</button>
                <a href="{{ backUrl }}" class="btn-secondary">Abbrechen</a>
            </div>
        {{ form_end(form) }}
    </div>
</div>
{% endblock %}
