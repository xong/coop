{% extends 'base.html.twig' %}

{% block title %}Benachrichtigungseinstellungen{% endblock %}

{% block body %}
<div class="max-w-2xl mx-auto">
    <div class="mb-6">
        <a href="{{ path('app_notifications') }}" class="text-indigo-600 hover:text-indigo-800 text-sm">&larr; Zurück</a>
        <h1 class="text-2xl font-bold text-gray-900 mt-2">Benachrichtigungseinstellungen</h1>
        <p class="text-gray-500 text-sm mt-1">Lege fest, worüber du benachrichtigt werden möchtest.</p>
    </div>

    <div class="card p-6">
        <form method="post">
            <input type="hidden" name="_token" value="{{ csrf_token('notif_settings') }}">

            <div class="mb-4 grid grid-cols-3 gap-4 text-xs font-semibold text-gray-500 uppercase tracking-wide border-b border-gray-100 pb-2">
                <span>Ereignis</span>
                <span class="text-center">In-App</span>
                <span class="text-center">E-Mail</span>
            </div>

            {% for eventType in eventTypes %}
                {% set s = settings[eventType] ?? null %}
                <div class="grid grid-cols-3 gap-4 items-center py-3 border-b border-gray-50">
                    <span class="text-sm text-gray-800">{{ constant('App\\Entity\\NotificationSetting::EVENT_LABELS')[eventType] }}</span>

                    {# In-app toggle #}
                    <div class="flex justify-center">
                        <label class="relative inline-flex items-center cursor-pointer">
                            <input type="checkbox" name="inapp_{{ eventType }}" value="1"
                                   {{ s and s.isInApp ? 'checked' : '' }}
                                   class="sr-only peer">
                            <div class="w-9 h-5 bg-gray-200 peer-checked:bg-indigo-600 rounded-full peer
                                        after:content-[''] after:absolute after:top-0.5 after:left-0.5
                                        after:bg-white after:rounded-full after:h-4 after:w-4
                                        after:transition-all peer-checked:after:translate-x-4"></div>
                        </label>
                    </div>

                    {# Email toggle + frequency #}
                    <div class="flex flex-col items-center space-y-1" x-data="{email: {{ s and s.isEmail ? 'true' : 'false' }}}">
                        <label class="relative inline-flex items-center cursor-pointer">
                            <input type="checkbox" name="email_{{ eventType }}" value="1"
                                   x-model="email"
                                   {{ s and s.isEmail ? 'checked' : '' }}
                                   class="sr-only peer">
                            <div class="w-9 h-5 bg-gray-200 peer-checked:bg-indigo-600 rounded-full peer
                                        after:content-[''] after:absolute after:top-0.5 after:left-0.5
                                        after:bg-white after:rounded-full after:h-4 after:w-4
                                        after:transition-all peer-checked:after:translate-x-4"></div>
                        </label>
                        <select name="freq_{{ eventType }}" x-show="email" x-cloak
                                class="text-xs border border-gray-200 rounded px-1 py-0.5">
                            <option value="immediate" {{ s and s.emailFrequency == 'immediate' ? 'selected' : '' }}>Sofort</option>
                            <option value="digest" {{ s and s.emailFrequency == 'digest' ? 'selected' : '' }}>Tägl. Zusammenfassung</option>
                        </select>
                    </div>
                </div>
            {% endfor %}

            <div class="mt-6">
                <button type="submit" class="btn-primary">Einstellungen speichern</button>
            </div>
        </form>
    </div>
</div>
{% endblock %}
