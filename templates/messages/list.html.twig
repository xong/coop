{% extends 'base.html.twig' %}

{% block title %}Nachrichten{% endblock %}

{% block body %}
<div class="max-w-2xl mx-auto">
    <div class="flex items-center justify-between mb-6">
        <h1 class="text-2xl font-bold text-gray-900">Nachrichten</h1>
        <a href="{{ path('app_message_new') }}" class="btn-primary btn-sm">+ Neue Nachricht</a>
    </div>

    {% if conversations is empty %}
        <div class="card p-10 text-center">
            <div class="text-4xl mb-3">&#128172;</div>
            <h3 class="font-medium text-gray-900 mb-2">Noch keine Nachrichten</h3>
            <p class="text-gray-500 mb-4">Schreibe eine direkte Nachricht oder starte eine Gruppenunterhaltung.</p>
            <a href="{{ path('app_message_new') }}" class="btn-primary">Neue Nachricht</a>
        </div>
    {% else %}
        <div class="card divide-y divide-gray-100">
            {% for conv in conversations %}
                {% set unread = conv.getUnreadCount(app.user) %}
                {% set lastMsg = conv.lastMessage %}
                <a href="{{ path('app_message_show', {id: conv.id}) }}"
                   class="flex items-center p-4 hover:bg-gray-50 transition-colors group {{ unread > 0 ? 'bg-blue-50/30' : '' }}">

                    {# Avatar / Icon #}
                    {% if conv.isDirect %}
                        {% set other = conv.getOtherParticipant(app.user) %}
                        <div class="w-10 h-10 rounded-full bg-indigo-100 flex items-center justify-center mr-3 flex-shrink-0">
                            {% if other and other.avatar %}
                                <img src="{{ asset(other.avatar) }}" class="w-10 h-10 rounded-full object-cover">
                            {% else %}
                                <span class="text-indigo-700 font-bold text-sm">
                                    {{ other ? other.firstName|first ~ other.lastName|first : '?' }}
                                </span>
                            {% endif %}
                        </div>
                    {% else %}
                        <div class="w-10 h-10 rounded-full bg-purple-100 flex items-center justify-center mr-3 flex-shrink-0">
                            <span class="text-purple-700 text-lg">&#128101;</span>
                        </div>
                    {% endif %}

                    <div class="flex-1 min-w-0">
                        <div class="flex items-baseline justify-between">
                            <span class="font-{{ unread > 0 ? 'semibold' : 'medium' }} text-gray-900 truncate mr-2">
                                {{ conv.getDisplayTitle(app.user) }}
                            </span>
                            {% if conv.lastMessageAt %}
                                <span class="text-xs text-gray-400 flex-shrink-0">{{ conv.lastMessageAt|date('d.m. H:i') }}</span>
                            {% endif %}
                        </div>
                        <p class="text-sm text-{{ unread > 0 ? 'gray-700' : 'gray-400' }} truncate mt-0.5">
                            {% if lastMsg and not lastMsg.isDeleted %}
                                {% if lastMsg.sender == app.user %}Du: {% endif %}
                                {{ lastMsg.content|slice(0, 80) }}
                            {% else %}
                                <em>Keine Nachrichten</em>
                            {% endif %}
                        </p>
                    </div>

                    {% if unread > 0 %}
                        <span class="ml-3 w-5 h-5 rounded-full bg-indigo-600 text-white text-xs flex items-center justify-center flex-shrink-0">
                            {{ unread > 9 ? '9+' : unread }}
                        </span>
                    {% endif %}
                </a>
            {% endfor %}
        </div>
    {% endif %}
</div>
{% endblock %}
