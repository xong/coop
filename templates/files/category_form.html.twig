{% extends 'base.html.twig' %}

{% block title %}Kategorie erstellen{% endblock %}

{% block body %}
<div class="max-w-md mx-auto">
    <div class="mb-6">
        <a href="{{ backUrl }}" class="text-indigo-600 hover:text-indigo-800 text-sm">&larr; Zurück</a>
        <h1 class="text-2xl font-bold text-gray-900 mt-2">Kategorie erstellen</h1>
    </div>
    <div class="card p-6">
        {{ form_start(form, {attr: {class: 'space-y-5'}}) }}
            <div>
                {{ form_label(form.name, null, {label_attr: {class: 'form-label'}}) }}
                {{ form_widget(form.name, {attr: {class: 'form-input'}}) }}
                {{ form_errors(form.name) }}
            </div>
            <div>
                {{ form_label(form.description, null, {label_attr: {class: 'form-label'}}) }}
                {{ form_widget(form.description, {attr: {class: 'form-input'}}) }}
                {{ form_errors(form.description) }}
            </div>
            {% if form.parent is defined %}
                <div>
                    {{ form_label(form.parent, null, {label_attr: {class: 'form-label'}}) }}
                    {{ form_widget(form.parent, {attr: {class: 'form-input'}}) }}
                    {{ form_errors(form.parent) }}
                </div>
            {% endif %}
            <div class="flex space-x-3 pt-2">
                <button type="submit" class="btn-primary">Kategorie erstellen</button>
                <a href="{{ backUrl }}" class="btn-secondary">Abbrechen</a>
            </div>
        {{ form_end(form) }}
    </div>
</div>
{% endblock %}
