{% extends 'base.html.twig' %}

{% block title %}Beitrag bearbeiten{% endblock %}

{% block body %}
<div class="max-w-3xl mx-auto">
    <div class="mb-6">
        <a href="{{ path('app_topic_show', {id: topic.id}) }}" class="text-indigo-600 hover:text-indigo-800 text-sm">&larr; Zurück zum Thema</a>
        <h1 class="text-2xl font-bold text-gray-900 mt-2">Beitrag bearbeiten</h1>
        <p class="text-sm text-gray-500 mt-1">in: <strong>{{ topic.title }}</strong></p>
    </div>

    <div class="card p-6">
        {{ form_start(form, {attr: {class: 'space-y-5'}}) }}
            {{ form_widget(form.content, {attr: {class: 'form-input'}}) }}
            {{ form_errors(form.content) }}
            <div class="flex space-x-3 pt-2">
                <button type="submit" class="btn-primary">Speichern</button>
                <a href="{{ path('app_topic_show', {id: topic.id}) }}" class="btn-secondary">Abbrechen</a>
            </div>
        {{ form_end(form) }}
    </div>
</div>
{% endblock %}
